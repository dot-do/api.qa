{
  "name": "api.qa",
  "version": "0.1.0",
  "description": "The external third-party verifier for agent-first APIs. Discovery from published machine surfaces, contract-derived deterministic checks, attested public grade reports.",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "api",
    "qa",
    "verification",
    "agent",
    "mcp",
    "openapi",
    "llms.txt",
    "attestation"
  ],
  "files": [
    "dist",
    "README.md",
    "DESIGN.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "api.qa": "dist/cli/index.js"
  },
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "self-test": "vitest run test/self.test.ts",
    "dev": "wrangler dev"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
